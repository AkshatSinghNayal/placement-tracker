# =============================================================================
# OfferForge backend — environment variables.
# Copy to .env and fill in. Every variable below has a sensible default for
# local `docker compose up` EXCEPT the secrets (JWT_SECRET, Google + Cloudinary).
# =============================================================================

# --- Server -----------------------------------------------------------------
# Port Express listens on. Render injects PORT automatically — leave 8000 locally.
PORT=8000
# dev | prod | test. "prod" enforces https-only cookies + rejects dev JWT secret.
APP_ENV=dev

# --- Database ---------------------------------------------------------------
# Local docker-compose uses the in-network "mongodb" service hostname.
# Production (Render) should point at MongoDB Atlas:
#   mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/placement_tracker?retryWrites=true&w=majority
MONGODB_URI=mongodb://mongodb:27017/placement_tracker

# --- Auth: access JWT -------------------------------------------------------
# IMPORTANT: the frontend keeps the access token ONLY in memory and refreshes it
# via POST /auth/refresh (httpOnly cookie). So the access token should be
# SHORT-LIVED. JWT_EXPIRES_IN accepts a vercel/ms string ("15m", "1h", "7d").
# Keep this short; refresh-token rotation handles long sessions.
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=15m
# Used by the internal signer if you want to override the env default.
ACCESS_TOKEN_TTL_MINUTES=15

# --- Auth: refresh token (opaque, httpOnly cookie) --------------------------
# Refresh tokens are random 32-byte secrets, stored SHA-256-hashed in MongoDB,
# sent to the browser only via the httpOnly "refresh_token" cookie.
# Rotation: every /auth/refresh revokes the old token and issues a new one.
REFRESH_TOKEN_TTL_DAYS=7

# --- Auth: password reset ---------------------------------------------------
PASSWORD_RESET_TTL_MINUTES=30

# --- Google OAuth (passport-google-oauth20) ---------------------------------
# Redirect URI registered in Google Cloud Console MUST be:
#   ${BACKEND_URL}/api/v1/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Cloudinary (resume PDF uploads) ----------------------------------------
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Optional: single-url form (takes precedence over the three vars above).
# cloudinary://api_key:api_secret@cloud_name
CLOUDINARY_URL=

# --- URLs (CORS + cookie SameSite + OAuth redirects) ------------------------
# frontend origin (Vercel in prod). Used for CORS allow-origin + OAuth redirect.
FRONTEND_URL=http://localhost:5173
# backend public origin (Render in prod). Used for OAuth callback redirect_uri.
BACKEND_URL=http://localhost:8000

# --- Optional: password-reset email stub hook -------------------------------
# If set, the stubbed reset "email" is also written to this file (for tests
# to extract the token). Leave empty for normal use.
EMAIL_STUB_FILE=
